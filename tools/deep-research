#!/usr/bin/env bash
# deep-research — Analyst-grade research reports via Exa Research API
# Analogous to: mcp__parallel-task__createDeepResearch
#
# Uses Exa's agentic research endpoint: the API decomposes your instructions,
# runs multiple searches, reads pages, reasons over facts, and returns a
# structured report with citations.
#
# Usage:
#   deep-research "Competitive landscape of AI contract management platforms"
#   deep-research -o report.md "legaltech startups series A 2024-2025"
#   deep-research --model pro --schema schema.json "CLM market analysis"

set -euo pipefail

: "${EXA_API_KEY:?EXA_API_KEY not set}"

EXA_BASE="https://api.exa.ai"

# Defaults
MODEL="exa-research"
OUTPUT=""
SCHEMA_FILE=""
POLL_INTERVAL=5
TIMEOUT=300
RAW_JSON=false
VERBOSE=false

usage() {
  cat <<'EOF'
deep-research — Analyst-grade research via Exa Research API

USAGE:
  deep-research [OPTIONS] "research instructions"

OPTIONS:
  -m, --model MODEL    Model: fast|default|pro (default: default)
                         fast = exa-research-fast (~15-30s, cheapest)
                         default = exa-research (~45-90s, adaptive)
                         pro = exa-research-pro (~90-180s, max quality)
  -s, --schema FILE    JSON Schema file for structured output
  -o, --output FILE    Write report to file (default: stdout)
  --poll NUM           Poll interval in seconds (default: 5)
  --timeout NUM        Max wait time in seconds (default: 300)
  --json               Output raw JSON response
  -v, --verbose        Show progress details
  -h, --help           Show this help

HOW IT WORKS:
  The Exa Research API is an agentic pipeline that:
  1. Plans — decomposes your instructions into research steps
  2. Searches — issues semantic queries, expanding and refining results
  3. Reasons — synthesizes facts across sources into a grounded report

  You get back either structured JSON (with --schema) or a markdown report
  with citations. The API handles all search/read/reasoning internally.

EXAMPLES:
  # Basic research report
  deep-research "Competitive landscape of AI contract management platforms"

  # Pro model with file output
  deep-research --model pro -o report.md "legaltech market analysis 2025"

  # Structured output with JSON schema
  deep-research --schema competitors.json "Compare top 5 CLM vendors"

  # Fast model for quick lookups
  deep-research -m fast "What is Ironclad's latest funding round?"

SCHEMA EXAMPLE (competitors.json):
  {
    "type": "object",
    "required": ["competitors"],
    "properties": {
      "competitors": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "founded", "funding", "description"],
          "properties": {
            "name": {"type": "string"},
            "founded": {"type": "string"},
            "funding": {"type": "string"},
            "description": {"type": "string"}
          }
        }
      }
    }
  }
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m|--model)
      case "$2" in
        fast)    MODEL="exa-research-fast" ;;
        default) MODEL="exa-research" ;;
        pro)     MODEL="exa-research-pro" ;;
        *)       MODEL="$2" ;;
      esac
      shift 2 ;;
    -s|--schema)   SCHEMA_FILE="$2"; shift 2 ;;
    -o|--output)   OUTPUT="$2"; shift 2 ;;
    --poll)        POLL_INTERVAL="$2"; shift 2 ;;
    --timeout)     TIMEOUT="$2"; shift 2 ;;
    --json)        RAW_JSON=true; shift ;;
    -v|--verbose)  VERBOSE=true; shift ;;
    -h|--help)     usage ;;
    -*)            echo "Unknown option: $1" >&2; exit 1 ;;
    *)             INSTRUCTIONS="$1"; shift ;;
  esac
done

: "${INSTRUCTIONS:?No instructions provided. Usage: deep-research \"your research topic\"}"

log() { [[ "$VERBOSE" == true ]] && echo "  [deep-research] $*" >&2 || true; }

# ─── Create Research Task ─────────────────────────────────────────────
build_payload() {
  local payload
  payload=$(jq -n \
    --arg instructions "$INSTRUCTIONS" \
    --arg model "$MODEL" \
    '{instructions: $instructions, model: $model}')

  if [[ -n "$SCHEMA_FILE" ]]; then
    if [[ ! -f "$SCHEMA_FILE" ]]; then
      echo "Schema file not found: $SCHEMA_FILE" >&2
      exit 1
    fi
    payload=$(echo "$payload" | jq --slurpfile schema "$SCHEMA_FILE" '. + {outputSchema: $schema[0]}')
  fi

  echo "$payload"
}

echo "── deep-research ───────────────────────────────────" >&2
echo "  model:   $MODEL" >&2
echo "  topic:   ${INSTRUCTIONS:0:80}$([ ${#INSTRUCTIONS} -gt 80 ] && echo '...')" >&2
[[ -n "$SCHEMA_FILE" ]] && echo "  schema:  $SCHEMA_FILE" >&2
echo "────────────────────────────────────────────────────" >&2

PAYLOAD=$(build_payload)
log "payload: $PAYLOAD"

echo "" >&2
echo "  Creating research task..." >&2

CREATE_RESPONSE=$(curl -sS -X POST "$EXA_BASE/research/v1" \
  -H "x-api-key: $EXA_API_KEY" \
  -H 'Content-Type: application/json' \
  -d "$PAYLOAD")

# Check for errors
if echo "$CREATE_RESPONSE" | jq -e '.error // .message' &>/dev/null 2>&1; then
  ERROR=$(echo "$CREATE_RESPONSE" | jq -r '.error // .message // "Unknown error"')
  echo "  ERROR: $ERROR" >&2
  log "full response: $CREATE_RESPONSE"
  exit 1
fi

RESEARCH_ID=$(echo "$CREATE_RESPONSE" | jq -r '.researchId')
STATUS=$(echo "$CREATE_RESPONSE" | jq -r '.status')

if [[ -z "$RESEARCH_ID" || "$RESEARCH_ID" == "null" ]]; then
  echo "  ERROR: No researchId returned" >&2
  echo "  Response: $CREATE_RESPONSE" >&2
  exit 1
fi

echo "  Task created: $RESEARCH_ID (status: $STATUS)" >&2

# ─── Poll Until Complete ──────────────────────────────────────────────
ELAPSED=0
LAST_STATUS=""

while [[ $ELAPSED -lt $TIMEOUT ]]; do
  sleep "$POLL_INTERVAL"
  ELAPSED=$((ELAPSED + POLL_INTERVAL))

  POLL_RESPONSE=$(curl -sS -X GET "$EXA_BASE/research/v1/$RESEARCH_ID" \
    -H "x-api-key: $EXA_API_KEY")

  STATUS=$(echo "$POLL_RESPONSE" | jq -r '.status')

  if [[ "$STATUS" != "$LAST_STATUS" ]]; then
    echo "  Status: $STATUS (${ELAPSED}s)" >&2
    LAST_STATUS="$STATUS"
  else
    log "polling... status=$STATUS elapsed=${ELAPSED}s"
  fi

  case "$STATUS" in
    completed|complete)
      echo "  Completed in ${ELAPSED}s" >&2
      break
      ;;
    failed|error)
      ERROR=$(echo "$POLL_RESPONSE" | jq -r '.error // "Unknown error"')
      echo "  FAILED: $ERROR" >&2
      log "full response: $POLL_RESPONSE"
      exit 1
      ;;
    running|pending|processing)
      continue
      ;;
    *)
      log "unexpected status: $STATUS"
      continue
      ;;
  esac
done

if [[ $ELAPSED -ge $TIMEOUT ]]; then
  echo "  TIMEOUT after ${TIMEOUT}s (task $RESEARCH_ID may still be running)" >&2
  echo "  Check manually: curl -H 'x-api-key: \$EXA_API_KEY' $EXA_BASE/research/v1/$RESEARCH_ID" >&2
  exit 1
fi

# ─── Output Results ───────────────────────────────────────────────────
COST=$(echo "$POLL_RESPONSE" | jq -r '.costDollars // "n/a"')
echo "  Cost: \$$COST" >&2
echo "────────────────────────────────────────────────────" >&2
echo "" >&2

if [[ "$RAW_JSON" == true ]]; then
  RESULT=$(echo "$POLL_RESPONSE" | jq .)
else
  # Extract the output — could be structured JSON or markdown text
  HAS_OUTPUT=$(echo "$POLL_RESPONSE" | jq -e '.output' &>/dev/null && echo true || echo false)

  if [[ "$HAS_OUTPUT" == true ]]; then
    OUTPUT_TYPE=$(echo "$POLL_RESPONSE" | jq -r '.output | type')
    if [[ "$OUTPUT_TYPE" == "string" ]]; then
      RESULT=$(echo "$POLL_RESPONSE" | jq -r '.output')
    else
      RESULT=$(echo "$POLL_RESPONSE" | jq '.output')
    fi
  else
    # Try .data, .result, or fall back to full response
    for field in data result results text; do
      HAS=$(echo "$POLL_RESPONSE" | jq -e ".$field" &>/dev/null && echo true || echo false)
      if [[ "$HAS" == true ]]; then
        FIELD_TYPE=$(echo "$POLL_RESPONSE" | jq -r ".$field | type")
        if [[ "$FIELD_TYPE" == "string" ]]; then
          RESULT=$(echo "$POLL_RESPONSE" | jq -r ".$field")
        else
          RESULT=$(echo "$POLL_RESPONSE" | jq ".$field")
        fi
        break
      fi
    done
    # Fallback: output everything except metadata
    if [[ -z "${RESULT:-}" ]]; then
      RESULT=$(echo "$POLL_RESPONSE" | jq 'del(.researchId, .status, .model, .instructions, .costDollars)')
    fi
  fi
fi

if [[ -n "$OUTPUT" ]]; then
  echo "$RESULT" > "$OUTPUT"
  echo "  Report written to: $OUTPUT" >&2
else
  echo "$RESULT"
fi
